#
# API-Football (api-football.com) configuration
#
# Note: Do NOT commit your real .env file.
#

# Example:
# base URL is for API-Football v3 direct API
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"

# Premier League league id is 39 in API-Football.
API_FOOTBALL_LEAGUE_ID="39"

# Season year used by the API (e.g. 2024 for 2024-2025 season)
API_FOOTBALL_SEASON="2024"

# Request timeout in seconds
API_FOOTBALL_TIMEOUT_SECONDS="30"

# Your API-Football key (used as header: x-apisports-key)
API_FOOTBALL_API_KEY="YOUR_API_KEY_HERE"

# Optional: logging verbosity
LOG_LEVEL="INFO"

# Database (SQLite-first)
# Default: data/pl_ingestion.sqlite
PL_DB_PATH="data/pl_ingestion.sqlite"
# Set to true for SQLAlchemy debug logging
DB_ECHO="false"

