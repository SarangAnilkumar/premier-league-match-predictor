      <aliases enabled='yes' />
      <column caption='Transfer Count' datatype='integer' name='[Calculation_100000000000000001]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Known Fee Flag' datatype='integer' name='[Calculation_100000000000000002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([fee_amount_numeric]) THEN 1 ELSE 0 END' />
      </column>
      <column caption='CF 03 Club PL Perspective' datatype='string' name='[Calculation_100000000000000003]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [movement_direction] = &quot;Incoming to PL&quot; OR [movement_direction] = &quot;Internal PL&quot; THEN [to_team_name] ELSE [from_team_name] END' />
      </column>
      <column caption='Incoming Fee' datatype='integer' name='[Calculation_100000000000000004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [movement_direction] = &quot;Incoming to PL&quot; OR [movement_direction] = &quot;Internal PL&quot; THEN ZN([fee_amount_numeric]) ELSE 0 END' />
      </column>
      <column caption='Outgoing Fee' datatype='integer' name='[Calculation_100000000000000005]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [movement_direction] = &quot;Outgoing from PL&quot; OR [movement_direction] = &quot;Internal PL&quot; THEN ZN([fee_amount_numeric]) ELSE 0 END' />
      </column>
      <column caption='Net Spend' datatype='integer' name='[Calculation_100000000000000006]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_100000000000000004] - [Calculation_100000000000000005]' />
      </column>
      <column caption='Internal PL Count' datatype='integer' name='[Calculation_100000000000000007]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [movement_direction]=&quot;Internal PL&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Incoming Count' datatype='integer' name='[Calculation_100000000000000008]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [movement_direction]=&quot;Incoming to PL&quot; OR [movement_direction]=&quot;Internal PL&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Outgoing Count' datatype='integer' name='[Calculation_100000000000000009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [movement_direction]=&quot;Outgoing from PL&quot; OR [movement_direction]=&quot;Internal PL&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Known Fee Sum' datatype='integer' name='[Calculation_100000000000000010]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN([fee_amount_numeric])' />
      </column>
      <column caption='Fee Column Header' datatype='string' name='[Calculation_100000000000000011]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Fee&quot;' />
      </column>
      <column caption='Deal Key' datatype='string' name='[Calculation_1278452347428869]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR([player_id]) + &quot;|&quot; +&#10;STR([from_team_id]) + &quot;|&quot; +&#10;STR([to_team_id]) + &quot;|&quot; +&#10;STR([transfer_date])' />
      </column>
